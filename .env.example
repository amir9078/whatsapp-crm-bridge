# Copy to .env and fill in. NEVER commit .env.

# ── App ──
NODE_ENV=development
# Backend API + WebSocket port (web app runs on 3000 via `pnpm web:dev`)
PORT=4000
# Where the web app finds the backend (set in apps/web/.env.local if it differs)
NEXT_PUBLIC_API_URL=http://localhost:4000

# 32-byte hex key that encrypts WhatsApp session creds & CRM tokens at rest (M8).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# ── Database ──  (SQLite for dev, Postgres for prod — same Prisma schema)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/wcb?schema=public"

# ── Auth (M7) ──
# Set a password to require login on the web UI + API. Leave empty to disable auth (local dev).
AUTH_PASSWORD=
# Optional: HMAC secret for session tokens. Defaults to a key derived from AUTH_PASSWORD.
JWT_SECRET=

# ── CRM (M6) ──
# No env vars needed: connect your CRM (Odoo: base URL + database + username + API key)
# from the Settings screen — credentials are stored in the database (encrypted in M8).
# Odoo API key: Odoo → Settings → My Profile → Account Security → New API Key.
