# Copy to .env and fill in. NEVER commit .env.

# ── App ──
NODE_ENV=development
PORT=3000

# 32-byte hex key that encrypts WhatsApp session creds & CRM tokens at rest (M8).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# ── Database ──  (SQLite for dev, Postgres for prod — same Prisma schema)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/wcb?schema=public"

# ── Auth (M7) ──
AUTH_PASSWORD=
JWT_SECRET=

# ── HubSpot CRM (M6) ──
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/crm/hubspot/callback
