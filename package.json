{
  "name": "whatsapp-crm-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hostable bridge that links WhatsApp via QR (like WhatsApp Web) and auto-logs conversations to your CRM. No official API, no per-message fees.",
  "license": "MIT",
  "author": "Shaikh Amir Hussain",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
